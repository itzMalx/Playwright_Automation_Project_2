{
  "name": "playwright_project_2",
  "version": "1.0.0",
  "description": "Playwright BDD Automation Testing Framework using Cucumber and TypeScript",
  "main": "index.js",
  "scripts": {
    "pretest": "if exist reports rmdir /s /q reports",
    "test": "cucumber-js",
    "posttest": "tsx src/utilities/report.ts",
    "muhindhar": "cucumber-js --tags @Muhindhar --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "malavicka": "cucumber-js --tags @Malavicka --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "vetri": "cucumber-js --tags @Vetri --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "mylambigai": "cucumber-js --tags @Mylambigai --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "shobana": "cucumber-js --tags @Shobana --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "rerun": "cucumber-js @rerun.txt --format json:reports/cucumber-report.json --format allure-cucumberjs/reporter",
    "report": "tsx src/utilities/report.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation-testing",
    "typescript",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@cucumber/html-formatter": "^24.0.0",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "allure-commandline": "^2.43.0",
    "allure-cucumberjs": "^3.10.2",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "multiple-cucumber-html-reporter": "^3.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
